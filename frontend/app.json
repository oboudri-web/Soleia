{
  "expo": {
    "name": "Soleia",
    "slug": "soleia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "soleia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soleia.app",
      "buildNumber": "65",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Trouver les terrasses au soleil près de vous",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Recevoir les alertes terrasses ensoleillées même en arrière-plan",
        "NSLocationAlwaysUsageDescription": "Recevoir les alertes terrasses ensoleillées même en arrière-plan",
        "NSCameraUsageDescription": "Prendre une photo pour valider cette terrasse",
        "NSPhotoLibraryUsageDescription": "Partager une photo de la terrasse",
        "UIBackgroundModes": [
          "remote-notification",
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.soleia.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F5A623"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true,
            "kotlinVersion": "2.0.21",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          },
          "ios": {
            "newArchEnabled": true,
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Partagez une photo de la terrasse avec la communauté",
          "cameraPermission": "Prenez une photo pour valider cette terrasse"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Trouver les terrasses au soleil près de vous"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#F5A623",
          "defaultChannel": "default"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6ba787c6-7294-43e3-9795-3ff0377e702e"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
